# Server configurations
PORT=5000
NODE_ENV=development

# Database connections
DATABASE_URL=postgresql://traveltrek_admin:traveltrek_secure_password@localhost:5432/traveltrek

# Blockchain Node RPC Url (Ganache or Hardhat)
BLOCKCHAIN_PROVIDER_URL=http://localhost:8545

# Authentication secrets
JWT_SECRET=super_secret_traveltrek_jwt_token_auth

# SMS Gateway provider credentials (for SMS fallback layer)
SMS_GATEWAY_API_KEY=mock_api_key_for_telephony_gateway
SMS_GATEWAY_SECRET=mock_secret_for_telephony_gateway
SENDER_PHONE_NUMBER=+1234567890

          "type": "array",
          "required": true,
          "items": {
            "name":  { "type": "string", "example": "Priya Sharma" },
            "phone": { "type": "string", "example": "+919876543210" }
          },
          "description": "Tourist's saved emergency contacts"
        },
        "channel":              { "type": "string",   "required": true,  "const": "internet", "description": "Cascade layer identifier" }
      },
      "response_200_201": {
        "id": { "type": "string", "example": "SOS-1716400000123", "description": "Unique SOS incident ID assigned by backend" }
      },
      "timeout": "3 seconds"
    },


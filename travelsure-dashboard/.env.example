# ==============================================================================
# TravelSure Control Operations Centre - Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and fill in the values for local development.
# These variables will be injected at build-time by Vite.
# Use standard 'VITE_' prefix for exposing variables to the client-side code.

# 1. Real-Time Socket Server Endpoint
# The URL of the Node/WebSocket backend that broadcasts telemetry and alerts.
# Default for local development: http://localhost:4000
VITE_BACKEND_SOCKET_URL=http://localhost:4000

# 2. Google Maps API Key
# Required to render the Live Map, geocoding coordinates, and handling drawing overlays.
# Obtain a key from the Google Cloud Console (with Maps JavaScript API enabled).
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# 3. Mapbox Access Token (Optional / Future Compatibility)
# Only required if migrating back or extending components to use Mapbox GL.
VITE_MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_ACCESS_TOKEN_HERE
